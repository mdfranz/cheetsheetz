{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "*": "ask",
    "read": {
      "*.md": "allow",
      "*.env.*": "deny",
      "*.pem": "deny",
      "*.key": "deny",
      "*.p12": "deny",
      "*.pfx": "deny",
      "*.jks": "deny",
      "*credentials*": "deny",
      "*secret*": "deny",
      "*.keystore": "deny",
      ".git/config": "deny",
      "**/secrets/**": "deny",
      "**/private/**": "deny",
      "**/.aws/**": "deny",
      "**/.ssh/**": "deny",
      "**/.gnupg/**": "deny",
      "*docker-compose*.yml": "ask"
    },
    "edit": {
      "*": "ask",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.pem": "deny",
      "*.key": "deny",
      "*credentials*": "deny",
      "*secret*": "deny"
    },
    "bash": {
      "*": "ask",
      "git status *": "allow",
      "git diff *": "allow",
      "git log *": "allow",
      "grep *": "allow",
      "cat *.env*": "deny",
      "cat *secret*": "deny",
      "cat *credential*": "deny",
      "cat *.pem": "deny",
      "cat *.key": "deny",
      "printenv *": "deny",
      "env": "deny",
      "export *": "deny",
      "echo $*": "deny",
      "curl *": "ask",
      "wget *": "ask",
      "rm -rf *": "deny",
      "rm -r *": "deny"
    },
    "webfetch": "ask",
    "external_directory": "deny"
  }
}
